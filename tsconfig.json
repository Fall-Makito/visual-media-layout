{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "isolatedModules": true,
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noImplicitAny": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["main.ts", "src/**/*.ts", "tests/**/*.ts"]
}
